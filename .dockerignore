# ─── Contrôle de source ───────────────────────────────────────────────────────
.git
.gitignore
.gitattributes

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea
*.iml
*.iws

# ─── Build output ─────────────────────────────────────────────────────────────
# On exclut target/ entièrement : le builder recompile à l'intérieur du container.
# Pas besoin d'exception !target/*.jar — le JAR n'est jamais copié depuis le host.
target/

# ─── Secrets et config locaux ─────────────────────────────────────────────────
.env
.env.*
gcp-key.json
*.json.key

# ─── CI / DevOps (inutiles pour le build de l'image) ─────────────────────────
Dockerfile
docker-compose*.yml
Jenkinsfile
sonar-project.properties
monitoring/

# ─── Claude Code (interne à l'outil) ─────────────────────────────────────────
.claude/

# ─── Divers ───────────────────────────────────────────────────────────────────
*.md
*.log
node_modules/
frontend/
